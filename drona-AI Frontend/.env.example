# ═══════════════════════════════════════════════════════════════════════════════
# DRONA AI — Frontend Environment Configuration (.env.example)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your actual values
# DO NOT commit real values to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 1. CORE APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Drona AI
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# 2. API ENDPOINTS
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=30000

# ─────────────────────────────────────────────────────────────────────────────
# 3. AUTHENTICATION — SUPABASE
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────────────────────────────────────
# 4. DESIGN SYSTEM & THEMES
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_THEME_DEFAULT=light
NEXT_PUBLIC_COLOR_MAIN_LEARNING=#2a5cff
NEXT_PUBLIC_COLOR_TEST=#e8362a
NEXT_PUBLIC_COLOR_GAME=#c9a84c
NEXT_PUBLIC_COLOR_WORKSPACE=#00c896
NEXT_PUBLIC_COLOR_RESOURCES=#9b5de5
NEXT_PUBLIC_COLOR_CAREER=#1a1a2e

# ─────────────────────────────────────────────────────────────────────────────
# 5. ANALYTICS & TRACKING
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_POSTHOG_API_KEY=your-posthog-api-key
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# 6. ERROR TRACKING
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────────
# 7. FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_IMAGE_SOLVER=true
NEXT_PUBLIC_FEATURE_VOICE_CHAT=false
NEXT_PUBLIC_FEATURE_MULTIPLAYER_BATTLES=true
NEXT_PUBLIC_FEATURE_PARENT_REPORTS=true
NEXT_PUBLIC_FEATURE_BYOK=true
NEXT_PUBLIC_FEATURE_FLASHCARDS=false
NEXT_PUBLIC_FEATURE_CAREER_GUIDANCE=false

# ─────────────────────────────────────────────────────────────────────────────
# 8. UI/UX CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ANIMATIONS_ENABLED=true
NEXT_PUBLIC_TOAST_DURATION=5000
NEXT_PUBLIC_ITEMS_PER_PAGE=20

# ─────────────────────────────────────────────────────────────────────────────
# 9. PWA & OFFLINE SUPPORT
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_CACHE_STRATEGY=service-worker

# ─────────────────────────────────────────────────────────────────────────────
# 10. PAYMENT & SUBSCRIPTION
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUBSCRIPTION_ENABLED=true
NEXT_PUBLIC_PAYMENT_PROVIDER=razorpay
NEXT_PUBLIC_RAZORPAY_KEY=your-razorpay-public-key

# ─────────────────────────────────────────────────────────────────────────────
# 11. THIRD-PARTY INTEGRATIONS
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# ─────────────────────────────────────────────────────────────────────────────
# 12. CHAT & STREAMING
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAT_MAX_HISTORY_LENGTH=100
NEXT_PUBLIC_CHAT_STREAMING_ENABLED=true
NEXT_PUBLIC_CHAT_RETRY_ATTEMPTS=3

# ─────────────────────────────────────────────────────────────────────────────
# 13. GAMIFICATION
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GAMIFICATION_ENABLED=true
NEXT_PUBLIC_LEADERBOARD_REFRESH_INTERVAL=60000

# ─────────────────────────────────────────────────────────────────────────────
# 14. NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_NOTIFICATIONS_ENABLED=true
NEXT_PUBLIC_DESKTOP_NOTIFICATIONS_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# 15. LOGGING & DEBUG
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# 16. SEO & META TAGS
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://drona-ai.com
NEXT_PUBLIC_SITE_NAME=Drona AI
NEXT_PUBLIC_SITE_DESCRIPTION=India's First Multi-Agent AI Education System

# ─────────────────────────────────────────────────────────────────────────────
# 17. FILE HANDLING
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAX_FILE_SIZE_MB=50
NEXT_PUBLIC_ALLOWED_FILE_TYPES=pdf,jpg,png,docx,txt

# ═══════════════════════════════════════════════════════════════════════════════
# END OF CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
