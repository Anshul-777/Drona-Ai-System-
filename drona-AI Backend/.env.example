# ═══════════════════════════════════════════════════════════════════════════════
# DRONA AI — Backend Environment Configuration (.env.example)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your actual values
# DO NOT commit real values to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 1. CORE APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Drona AI
APP_DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
ALGORITHM=HS256

# ─────────────────────────────────────────────────────────────────────────────
# 2. DATABASE — SUPABASE (PostgreSQL + Auth + Realtime)
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/drona_ai

# PostgreSQL Connection Details (if using direct connection)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=drona_ai
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ─────────────────────────────────────────────────────────────────────────────
# 3. AUTHENTICATION — JWT & SUPABASE AUTH
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─────────────────────────────────────────────────────────────────────────────
# 4. LLM PROVIDERS — Primary & Fallback Chain
# ─────────────────────────────────────────────────────────────────────────────

# 4a. GEMINI (Primary — Free Tier)
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# 4b. GROQ (Fallback #1 — Ultra-Fast)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# 4c. OPENROUTER (Fallback #2 — Multi-Model)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# 4d. BRING-YOUR-OWN-KEY (BYOK) — User Custom API Keys
BYOK_ENABLED=true

# 4e. OPENAI (Optional — if integrating later)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# 4f. ANTHROPIC (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus

# ─────────────────────────────────────────────────────────────────────────────
# 5. VECTOR DATABASE — PINECONE (RAG & Memory)
# ─────────────────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=drona-ai-knowledge
PINECONE_DIMENSION=768

# Namespace Strategy:
# - platform-rag: Curated platform knowledge (textbooks, past papers, concepts)
# - user-{user_id}-rag: Private user knowledge (personalized notes, solutions)
# - memory-{user_id}: Short-term conversation memory (24-hour retention)
PINECONE_NAMESPACES=platform-rag,user-rag,memory

# ─────────────────────────────────────────────────────────────────────────────
# 6. CACHE & QUEUE — UPSTASH REDIS + QSTASH
# ─────────────────────────────────────────────────────────────────────────────

# Redis (Session state, rate limiting, caching)
UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
REDIS_TTL_SESSION=3600
REDIS_TTL_CACHE=300
REDIS_TTL_RATE_LIMIT=60

# QStash (Background jobs, cron tasks — e.g., Teachers' Lounge review)
UPSTASH_QSTASH_TOKEN=your-qstash-token
QSTASH_SIGNING_KEY=your-qstash-signing-key

# ─────────────────────────────────────────────────────────────────────────────
# 7. FILE STORAGE — CLOUDFLARE R2 (S3-Compatible)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_BUCKET_NAME=drona-ai-storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ─────────────────────────────────────────────────────────────────────────────
# 8. OCR & VISION — GOOGLE CLOUD + MATHPIX
# ─────────────────────────────────────────────────────────────────────────────

# Google Cloud Vision (Text extraction from images)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/gcp-credentials.json

# Mathpix (Advanced math equation recognition)
MATHPIX_APP_ID=your-mathpix-app-id
MATHPIX_APP_KEY=your-mathpix-app-key

# ─────────────────────────────────────────────────────────────────────────────
# 9. EMBEDDINGS — Which Provider to Use
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDINGS_PROVIDER=gemini
# Options: gemini, openai, sentence-transformers (local)

# ─────────────────────────────────────────────────────────────────────────────
# 10. CORS & SECURITY
# ─────────────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://drona-ai.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# ─────────────────────────────────────────────────────────────────────────────
# 11. RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_FREE_PER_DAY=50
RATE_LIMIT_PRO_PER_DAY=500

# ─────────────────────────────────────────────────────────────────────────────
# 12. SUBSCRIPTION & PRICING
# ─────────────────────────────────────────────────────────────────────────────
PRICING_FREE_DAILY_LIMIT=50
PRICING_FREE_CHAT_LIMIT=10
PRICING_PRO_PRICE_INR=299
PRICING_ENTERPRISE_PRICE_INR=799

# ─────────────────────────────────────────────────────────────────────────────
# 13. GAMIFICATION — XP, LEVELS, LEADERBOARD
# ─────────────────────────────────────────────────────────────────────────────
XP_CORRECT_ANSWER=10
XP_TEST_COMPLETION=50
XP_STREAK_BONUS=5
XP_MISSION_COMPLETION=100
XP_BOSS_BATTLE_WIN=200
LEVEL_XP_MULTIPLIER=100
MAX_LEVEL=100
STREAK_RESET_HOURS=24

# ─────────────────────────────────────────────────────────────────────────────
# 14. AGENTS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
HEAD_AGENT_ENABLED=true
HEAD_AGENT_TIMEOUT_SECONDS=30
SUBJECT_AGENTS_ENABLED=true
GRADER_AGENT_ENABLED=true
MEMORY_AGENT_ENABLED=true
QUEST_AGENT_ENABLED=true
NOTIFICATION_AGENT_ENABLED=true
STATS_AGENT_ENABLED=true
LEARNING_STRATEGIST_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# 15. EMAIL & NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@drona-ai.com

# ─────────────────────────────────────────────────────────────────────────────
# 16. LOGGING & MONITORING
# ─────────────────────────────────────────────────────────────────────────────
LOG_FORMAT=json
LOG_LEVEL=INFO
SENTRY_DSN=https://your-sentry-dsn

# ─────────────────────────────────────────────────────────────────────────────
# 17. ANALYTICS & TELEMETRY
# ─────────────────────────────────────────────────────────────────────────────
ANALYTICS_ENABLED=true
POSTHOG_API_KEY=your-posthog-api-key

# ─────────────────────────────────────────────────────────────────────────────
# 18. PAYMENT & BILLING
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# ─────────────────────────────────────────────────────────────────────────────
# 19. FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────
FEATURE_IMAGE_SOLVER_ENABLED=true
FEATURE_VOICE_CHAT_ENABLED=false
FEATURE_MULTIPLAYER_BATTLES_ENABLED=true
FEATURE_PARENT_REPORTS_ENABLED=true
FEATURE_BYOK_ENABLED=true
FEATURE_FLASHCARDS_ENABLED=false
FEATURE_CAREER_GUIDANCE_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# 20. DEVELOPMENT & DEBUGGING
# ─────────────────────────────────────────────────────────────────────────────
DEBUG_MODE=false
VERBOSE_LOGGING=false
MOCK_LLM_RESPONSES=false

# ─────────────────────────────────────────────────────────────────────────────
# 21. API CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
WORKERS=4
WORKER_TIMEOUT=120

# ─────────────────────────────────────────────────────────────────────────────
# 22. INFRASTRUCTURE & DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────
RUN_MIGRATIONS_ON_STARTUP=true
MIGRATION_TIMEOUT_SECONDS=300
HEALTHCHECK_ENABLED=true
HEALTHCHECK_INTERVAL_SECONDS=30
APP_VERSION=1.0.0
LOG_LEVEL=INFO
